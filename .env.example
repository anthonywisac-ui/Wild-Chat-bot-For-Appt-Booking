# Copy to .env and fill in real values. Never commit the real .env.

# ── Core platform ──────────────────────────────────────────────────────────
BOT_TYPE=appointment
DATABASE_URL=sqlite:///./platform.db
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ADMIN_PASSWORD=change-me
ALLOW_DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── WhatsApp: Meta Cloud API (per-bot overrides also available in CMS) ────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=token123
WHATSAPP_API_VERSION=v19.0

# ── WhatsApp: self-hosted wwebjs bridge (alternative to Meta API) ─────────
WWEBJS_BRIDGE_URL=http://localhost:3000
BRIDGE_API_KEY=
BRIDGE_INTERNAL_SECRET=

# ── AI providers (set at least one) ────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── RAG knowledge base ──────────────────────────────────────────────────────
VECTOR_STORE_DIR=vector_store
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── PDF confirmations ───────────────────────────────────────────────────────
PDF_OUTPUT_DIR=/tmp/appointment_pdfs

# ── Optional integrations ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
