# ============================================================
# wa-bridge environment variables
# Copy this file to .env and fill in values
# ============================================================

# Port the bridge listens on (default 3000)
PORT=3000

# API key that protects the bridge REST API
# FastAPI will send this in X-Bridge-Key header
# Generate with: openssl rand -hex 32
BRIDGE_API_KEY=change-me-use-openssl-rand-hex-32

# Internal secret — bridge sends this to FastAPI webhook so FastAPI
# can verify the request really came from the bridge (not the internet)
# Generate with: openssl rand -hex 32
BRIDGE_INTERNAL_SECRET=change-me-use-openssl-rand-hex-32

# URL of your FastAPI /wwebjs/webhook endpoint
# If running locally: http://localhost:8000/wwebjs/webhook
# If on same Docker network: http://fastapi:8000/wwebjs/webhook
FASTAPI_WEBHOOK_URL=http://localhost:8000/wwebjs/webhook

# Where to store WhatsApp session files (absolute or relative to wa-bridge/)
# These files contain your WhatsApp auth tokens — back them up!
SESSIONS_DIR=./sessions
